# ════════════════════════════════════════════════
#  Configuration RÉSEAU LOCAL (copier → .env)
# ════════════════════════════════════════════════

# Mode debug activé = accepte toutes les IPs locales
DJANGO_DEBUG=True

# Clé secrète (changer pour production)
DJANGO_SECRET_KEY=clinique-cerine-local-secret-2026

# Base de données SQLite locale (aucune installation requise)
# DATABASE_URL=sqlite:///db.sqlite3

# Si vous utilisez PostgreSQL local :
# DATABASE_URL=postgres://user:password@localhost:5432/clinique_db

# Origines CSRF pour accès réseau local (remplacer l'IP par celle de votre PC)
# Exemple si le PC serveur est à 192.168.1.10 :
CSRF_TRUSTED_ORIGINS=http://192.168.1.10:8000,http://192.168.1.10
